// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Payment_Status {
  CREATED
  PENDING
  PENDING_PAYMENT
  CANCELLED
  PAID
}

enum Jenis_Pertandingan {
  OPEN
  RANK
}

enum Add_Ons {
  AIR_MINERAL
}

model kolam {
  id              Int   @id @default(autoincrement())
  label           Int   @db.Integer
  jumlah_pancang  Int   @db.Integer
  kolam_bookings  kolam_booking[]
  kolam_booking_kolams  kolam_booking_kolams[]
  pancangs        pancang[]
  booking_availabilities      booking_availability[]

}

model tarikh_memancing {
  id Int @id @default(autoincrement())
  is_deleted Boolean @db.Boolean @default(false)
  tarikh DateTime @db.Timestamptz(6)
  created_on DateTime @db.Timestamptz(6)
}

model admin {
  id             Int @id @default(autoincrement()) @unique
  username       String @db.Text @unique
  nama_pertama   String @db.Text
  nama_akhir     String @db.Text
  password       String @db.Text
  telefon        String @db.Text
  email          String @db.Text @unique
  forgot_password String? @db.Text
  timbang        timbang?
}

model user {
  id             Int @id @default(autoincrement())
  username       String @db.Text @unique
  nama_pertama   String @db.Text
  nama_akhir     String @db.Text
  password       String @db.Text
  telefon        String @db.Text
  email          String @db.Text @unique
  kolam_bookings kolam_booking[]
  verification_token String @db.Text
  is_verified       Boolean @db.Boolean @default(false)
  forgot_password String? @db.Text
}

model kolam_booking {
  id                          Int @id @default(autoincrement())
  kolam                       kolam?  @relation(fields: [kolam_id], references:[id])
  kolam_id                    Int?
  kolam_booking_kolams        kolam_booking_kolams[]
  pancangs                    kolam_booking_pancang[]
  add_ons                     kolam_booking_add_ons[]
  payment                     kolam_booking_payments?
  manual_receipts             kolam_booking_manual_receipts[]
  amount                      Decimal
  user                        user?  @relation(fields: [user_id], references:[id])
  user_id                     Int?
  payment_status              Payment_Status @default(CREATED)
  is_deleted                  Boolean  @default(false)
  tarikh                      DateTime @db.Timestamp(6)
  qr_link_file_name           String?   @db.Text       
  is_checked_in               Boolean  @db.Boolean @default(false)
  is_manual                   Boolean? @db.Boolean @default(false)
  is_deposit                  Boolean? @db.Boolean @default(false)
  deposit_amount              Int?
  manual_booking              manual_booking?
  voucher                     vouchers?      @relation(fields: [voucher_id], references: [id])
  voucher_id                  Int?
  check_in_on                 DateTime? @db.Timestamptz(6)
  created_on                  DateTime @db.Timestamptz(6) @default(now())
}

model kolam_booking_kolams {
  id                          Int                   @unique @default(autoincrement()) 
  kolam                       kolam                 @relation(fields: [kolam_id], references:[id])
  kolam_id                    Int     
  kolam_booking               kolam_booking         @relation(fields: [kolam_booking_id], references: [id])
  kolam_booking_id            Int                   
  kolam_booking_pancang       pancang               @relation(fields: [kolam_booking_pancang_id], references: [id])
  kolam_booking_pancang_id    Int    
  is_deleted                  Boolean               @db.Boolean @default(false)
}

model manual_booking {
  id                          Int @id       @default(autoincrement())
  nama_penuh                  String?       @db.Text
  telefon                     String?       @db.Text
  email                       String?       @db.Text
  kolam_booking               kolam_booking @relation(fields: [kolam_id], references: [id])
  kolam_id                    Int           @unique
}

model vouchers {
  id                          Int @id       @default(autoincrement())
  code                        String?       @db.Text 
  percentage_off              Decimal
  starts_on                   DateTime?
  expires_on                  DateTime?
  products                    products[]    @relation("ProductsVouchers")
  kolam_bookings              kolam_booking[]
}

model products { 
  id                          Int           @id @default(autoincrement())
  name                        String        @db.Text
  label                       String        @db.Text
  type                        String        @db.Text
  price                       Int
  quantity                    Int?
  vouchers                    vouchers[]    @relation("ProductsVouchers")
}

model kolam_booking_pancang {
  id                  Int @id @default(autoincrement())
  nombor              String? @db.Text
  kolam_booking       kolam_booking @relation(fields: [kolam_booking_id], references:[id])
  kolam_booking_id    Int
  created_on          DateTime  @default(now())
}

model kolam_booking_add_ons {
  id                          Int           @id @default(autoincrement())
  type                        Add_Ons      
  quantity                    Int
  kolam_booking               kolam_booking @relation(fields: [kolam_booking_id], references:[id])
  kolam_booking_id            Int
  created_on                  DateTime @default(now())
}

model kolam_booking_payments {
  id                          Int           @id @default(autoincrement()) 
  bill_code                   String?       @db.Text
  ref_no                      String?       @db.Text
  status                      String?       @db.Text
  fpx_transaction_id          String?       @db.Text
  transaction_id              String?       @db.Text
  reason                      String?       @db.Text
  kolam_booking               kolam_booking @relation(fields: [kolam_booking_id], references:[id])
  kolam_booking_id            Int           @unique
  transaction_time            DateTime?
}

model kolam_booking_manual_receipts {
  id                          Int           @id @default(autoincrement()) 
  receipt                     String?
  kolam_booking               kolam_booking @relation(fields: [kolam_booking_id], references:[id])
  kolam_booking_id            Int           
}

model pancang {
  id                          Int            @id @unique @default(autoincrement()) 
  value                       String         @db.Text @unique
  kolam                       kolam          @relation(fields: [kolam_id], references:[id])
  kolam_id                    Int            
  is_left                     Boolean?       @default(false)
  is_right                    Boolean?       @default(false)
  booking_availabilities      booking_availability[]
  kolam_booking_kolams        kolam_booking_kolams[]
  pertandingan_audit_logs     pertandingan_audit_log[]
  is_deleted                  Boolean        @default(false)
  is_available                Boolean        @default(true)
}

model booking_availability {
  id                          Int            @id @default(autoincrement()) 
  kolam                       kolam          @relation(fields: [kolam_id], references:[id])
  kolam_id                    Int           
  tarikh                      DateTime?
  pancang                     pancang        @relation(fields: [pancang_id], references:[id])
  pancang_id                  Int         
  is_available                Boolean        @default(true)   
  @@unique([pancang_id, kolam_id, tarikh])
}

model pertandingan {
  id                          Int            @id @default(autoincrement())
  tarikh                      DateTime?
  jenis                       Jenis_Pertandingan?
  poster_url                  String?
  is_deleted                  Boolean        @default(false)
  pertandingan_audit_logs     pertandingan_audit_log[]
  is_started                  Boolean         @default(false)
  is_ended                    Boolean         @default(false)
  @@unique([tarikh])
}

model pertandingan_audit_log {
  id                          Int            @id @default(autoincrement()) @unique
  pertandingan                pertandingan   @relation(fields: [pertandingan_id], references:[id])
  pertandingan_id             Int
  pancang                     pancang        @relation(fields: [pancang_value], references:[value])
  pancang_value               String                         
  berat                       Decimal        @db.Decimal(18,6)
  timbang                     timbang        @relation(fields: [timbang_id], references:[id])
  waktu                       DateTime       @default(now())
  timbang_id                  Int           
  is_deleted                  Boolean        @default(false)
}

model timbang { 
  id                          Int            @id @default(autoincrement()) @unique
  label                       String  
  pertandingan_audit_logs     pertandingan_audit_log[]
  admin                       admin?  @relation(fields: [admin_id], references:[id])
  admin_id                    Int?           @unique
  is_deleted                  Boolean        @default(false)
}